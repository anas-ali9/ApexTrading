# ─────────────────────────────────────────────────────────────
# APEXTRADE — Environment Variables
# Copy this to .env locally, OR paste into Railway's Variables panel
# ─────────────────────────────────────────────────────────────

# PORT is set automatically by Railway — DO NOT change this
# PORT=3000

# ── REQUIRED: Alpha Vantage (stocks, ETFs, daily OHLCV) ──────
# Free key: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, 5/min
ALPHA_VANTAGE_KEY=your_key_here

# ── RECOMMENDED: Finnhub (news + real-time quotes) ───────────
# Free key: https://finnhub.io/register
# Free tier: 60 calls/min
FINNHUB_KEY=your_key_here

# ── OPTIONAL: OpenAI (for richer AI signal narration) ────────
# Sign up: https://platform.openai.com
OPENAI_KEY=your_key_here
